{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/apply-freehand-move-patch.mjs && vite build",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy dist --project-name spine-annotator",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply spine-annotator-production --local",
    "db:migrate:remote": "wrangler d1 migrations apply spine-annotator-production --remote",
    "secret:auth": "wrangler pages secret put AUTH_PASSWORD --project-name spine-annotator"
  },
  "dependencies": {
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260609.1",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
